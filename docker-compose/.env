# Triage Observability Pipeline - Environment Variables
# Copy this to .env and set your own values

# API key for authenticating OTLP submissions and metrics access
# Envoy checks this key in the X-API-Key header on all external traffic
ENVOY_API_KEY=placeholder_api_key

# Triage service configuration
TRIAGE_REFRESH_SECONDS=60
TRIAGE_TOP_N=3
